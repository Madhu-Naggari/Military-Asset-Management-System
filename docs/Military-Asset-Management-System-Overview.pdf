(4. RBAC Explanation) Tj
T*
() Tj
T*
(Roles) Tj
T*
() Tj
T*
(Admin) Tj
T*
() Tj
T*
(* Full access to all bases and all modules) Tj
T*
(* Can view global dashboard data) Tj
T*
(* Can create purchases, transfers, assignments and expenditures) Tj
T*
() Tj
T*
(Base Commander) Tj
T*
() Tj
T*
(* Access restricted to their assigned base) Tj
T*
(* Can view dashboard data for their base) Tj
T*
(* Can create and view purchases, transfers, assignments and expenditures for their base) Tj
T*
() Tj
T*
(Logistics Officer) Tj
T*
() Tj
T*
(* Access restricted to their assigned base) Tj
T*
(* Can view dashboard data for their base) Tj
T*
(* Can create and view purchases and transfers) Tj
T*
(* Cannot create assignments or expenditures) Tj
T*
() Tj
T*
(Enforcement Method) Tj
T*
() Tj
T*
(* JWT authentication identifies the current user) Tj
T*
(* Express middleware protects routes) Tj
T*
(* Role authorization middleware checks operation-level access) Tj
T*
(* Base scope helpers prevent users from acting outside their assigned base) Tj
T*
() Tj
T*
(5. API Logging) Tj
ET
